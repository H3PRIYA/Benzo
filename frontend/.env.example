# ── BENZO Frontend — Environment Variables ───────────────────────────────
# Copy to .env.local for local dev (Vite auto-loads it).

# Leave empty in dev — Vite proxies /api → localhost:5000 automatically
# In production, set this to your deployed backend URL:
# VITE_API_URL=https://your-backend.com
VITE_API_URL=
